# Copy to config.env and adjust paths if needed.
# config.env is gitignored — each machine keeps its own copy.

# Role: producer | consumer
SYNC_MODE=producer

# Cursor home directory
CURSOR_HOME="$HOME/.cursor"

# Local repo path (this directory)
REPO_DIR="$HOME/ai-skills-rules"

# Git settings
GIT_BRANCH=main
GIT_REMOTE=origin

# What to sync (relative to CURSOR_HOME → relative to REPO_DIR)
SYNC_SKILLS=1
SYNC_RULES=1
# Built-in Cursor skills — usually skip on consumer machines
SYNC_SKILLS_CURSOR=0

# rsync: mirror deletions from source (producer) / from repo (consumer)
RSYNC_DELETE=1

# Log file
LOG_FILE="$REPO_DIR/logs/sync.log"
